{
  "$schema": "../../Schemas/PayrollEngine.CaseTest.schema.json",
  "testName": "Test.RegistrationNumber",
  "tenantIdentifier": "ActionTenant",
  "userIdentifier": "lucy.smith@foo.com",
  "employeeIdentifier": "mario.nuñez@foo.com",
  "payrollName": "ActionPayroll",
  "validateTests": [
    {
      "testName": "RegistrationNumber.Valid.999999996.Test",
      "input": {
        "userIdentifier": "lucy.smith@foo.com",
        "employeeIdentifier": "mario.nuñez@foo.com",
        "divisionName": "ActionDivision",
        "case": {
          "caseName": "EmployeeRegistration",
          "values": [
            {
              "caseFieldName": "RegistrationNumber",
              "value": "999999996"
            }
          ]
        }
      },
      "output": {
        "values": [
          {
            "caseFieldName": "RegistrationNumber",
            "value": "999999996"
          }
        ]
      }
    },
    {
      "testName": "RegistrationNumber.Invalid.999999997.Test",
      "input": {
        "userIdentifier": "lucy.smith@foo.com",
        "employeeIdentifier": "mario.nuñez@foo.com",
        "divisionName": "ActionDivision",
        "case": {
          "caseName": "EmployeeRegistration",
          "values": [
            {
              "caseFieldName": "RegistrationNumber",
              "value": "999999997"
            }
          ]
        }
      },
      "output": {
        "issues": [
          {
            "caseFieldName": "RegistrationNumber",
            "issueType": "CaseInvalid",
            "number": 400
          }
        ]
      }
    }
  ]
}
