          "wageTypes": [
            {
              "wageTypeNumber": 200,
              "name": "FRIncomeTax",
              "description": "French income tax deduction (Prelevement a la source) on gross income",
              "valueExpression": "Collector[\"GrossIncome\"] * CaseValue[\"FRIncomeTaxRate\"]",
              "collectors": [ "Deductions" ]
            },
            {
              "wageTypeNumber": 210,
              "name": "FRCSGCRDS",
