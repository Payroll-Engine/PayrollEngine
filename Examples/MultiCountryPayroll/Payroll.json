      "regulations": [
        {
          "name": "ACME.Global",
          "description": "Global base regulation: shared salary, employment level and company bonus across all country payrolls",
          "sharedRegulation": true,
          "cases": [
            {
              "name": "CompanyBonus",
              "description": "Company-wide bonus rate applied uniformly in all countries",
              "caseType": "Company",
              "fields": [
                {
                  "name": "CompanyBonusRate",
                  "valueType": "Percent",
                  "valueScope": "Global",
                  "timeType": "CalendarPeriod"
                }
              ]
            },
            {
              "name": "Salary",
              "description": "Employee monthly base salary — Global scope allows one value to be read from any country payroll",
              "caseType": "Employee",
              "fields": [
                {
                  "name": "Salary",
                  "valueType": "Money",
                  "valueScope": "Global",
                  "timeType": "CalendarPeriod"
                }
              ]
            },
            {
              "name": "EmploymentLevel",
              "description": "Employment percentage per country — not global, allowing split across countries (e.g. 60% DE + 40% FR)",
              "caseType": "Employee",
              "fields": [
                {
                  "name": "EmploymentLevel",
                  "valueType": "Percent",
                  "timeType": "Period"
                }
              ]
            }
          ],
          "collectors": [
            {
              "name": "GrossIncome",
              "description": "All income components"
            },
            {
              "name": "Deductions",
              "description": "All deductions (taxes + social contributions)"
            }
          ],
          "wageTypes": [
            {
              "wageTypeNumber": 100,
              "name": "BaseSalary",
              "description": "Monthly base salary scaled by the country-specific employment level",
              "valueExpression": "var v = GetCaseValues(\"Salary\", \"EmploymentLevel\"); return v[\"Salary\"] * v[\"EmploymentLevel\"];",
              "collectors": [ "GrossIncome" ]
            },
            {
              "wageTypeNumber": 110,
              "name": "CompanyBonus",
              "description": "Global company bonus as a percentage of base salary — same rate for all countries",
              "valueExpression": "WageType[100] * CaseValue[\"CompanyBonusRate\"]",
              "collectors": [ "GrossIncome" ]
            }
          ]
        },
        {
          "name": "ACME.DE",
          "description": "Germany payroll regulation: income tax (25%) and social insurance (20%)",
          "baseRegulations": [ "ACME.Global" ],
          "cases": [
            {
              "name": "DEIncomeTax",
              "description": "German income tax rate (simplified flat rate for demonstration)",
              "caseType": "National",
              "fields": [
                {
                  "name": "DEIncomeTaxRate",
                  "valueType": "Percent",
                  "timeType": "Period"
                }
              ]
            },
            {
              "name": "DESocialInsurance",
              "description": "German social insurance contribution rate (employee share)",
              "caseType": "National",
              "fields": [
                {
                  "name": "DESocialInsuranceRate",
                  "valueType": "Percent",
                  "timeType": "Period"
                }
              ]
            }
          ],
          "wageTypes": [
            {
              "wageTypeNumber": 200,
              "name": "DEIncomeTax",
              "description": "German income tax deduction on gross income",
              "valueExpression": "Collector[\"GrossIncome\"] * CaseValue[\"DEIncomeTaxRate\"]",
              "collectors": [ "Deductions" ]
            },
            {
              "wageTypeNumber": 210,
              "name": "DESocialInsurance",
              "description": "German social insurance deduction on gross income",
              "valueExpression": "Collector[\"GrossIncome\"] * CaseValue[\"DESocialInsuranceRate\"]",
              "collectors": [ "Deductions" ]
            }
          ]
        },
        {
          "name": "ACME.FR",
