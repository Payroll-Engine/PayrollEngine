      "regulations": [
        {
          "name": "RetroRegulation",
          "description": "Retro payroll regulation with salary, bonus, income tax and social security",
          "cases": [
            {
              "name": "Salary",
              "description": "Monthly base salary",
              "caseType": "Employee",
              "defaultReason": "Change monthly salary",
              "fields": [
                {
                  "name": "Salary",
                  "valueType": "Money",
                  "timeType": "CalendarPeriod"
                }
              ]
            },
            {
              "name": "EmploymentLevel",
              "description": "Employment percentage (1.0 = full-time)",
              "caseType": "Employee",
              "defaultReason": "Change employment level",
              "fields": [
                {
                  "name": "EmploymentLevel",
                  "valueType": "Percent",
                  "timeType": "Period"
                }
              ]
            },
            {
              "name": "Bonus",
              "description": "One-time bonus payment (Moment: applies to the pay period containing the bonus date)",
              "caseType": "Employee",
              "defaultReason": "Enter bonus",
              "fields": [
                {
                  "name": "Bonus",
                  "valueType": "Money",
                  "timeType": "Moment"
                }
              ]
            }
          ],
          "collectors": [
            {
              "name": "GrossIncome",
              "description": "Sum of base salary and bonus components"
            },
            {
              "name": "Deductions",
              "description": "Sum of income tax and social security deductions"
            }
          ],
          "wageTypes": [
            {
              "wageTypeNumber": 100,
              "name": "BaseSalary",
              "description": "Monthly salary scaled by employment level",
              "valueExpression": "var v = GetCaseValues(\"Salary\", \"EmploymentLevel\"); return v[\"Salary\"] * v[\"EmploymentLevel\"];",
              "collectors": [ "GrossIncome" ],
              "clusters": [ "Legal", "Retro" ]
            },
            {
              "wageTypeNumber": 102,
              "name": "BaseSalaryDelta",
              "description": "Sum of all retro-period corrections for WT 100 (positive = underpaid, negative = overpaid)",
              "valueExpression": "GetWageTypeRetroResultSum(100)",
              "clusters": [ "Legal" ]
            },
            {
              "wageTypeNumber": 110,
              "name": "Bonus",
              "description": "One-time bonus — Moment type, recognised in the pay period containing the bonus date",
              "valueExpression": "CaseValue[\"Bonus\"]",
              "collectors": [ "GrossIncome" ],
              "clusters": [ "Legal", "Retro" ]
            },
            {
              "wageTypeNumber": 112,
              "name": "BonusDelta",
              "description": "Sum of all retro-period corrections for WT 110",
              "valueExpression": "GetWageTypeRetroResultSum(110)",
              "clusters": [ "Legal" ]
            },
            {
              "wageTypeNumber": 200,
              "name": "IncomeTax",
              "description": "Simplified flat-rate income tax: 25% of gross income. Uses WageType references (not collector) to work in both normal and retro runs.",
              "valueExpression": "(WageType[100] + WageType[110]) * 0.25M",
              "collectors": [ "Deductions" ],
              "clusters": [ "Legal", "Retro" ]
            },
            {
              "wageTypeNumber": 202,
              "name": "IncomeTaxDelta",
              "description": "Sum of all retro-period corrections for WT 200",
              "valueExpression": "GetWageTypeRetroResultSum(200)",
              "clusters": [ "Legal" ]
            },
            {
              "wageTypeNumber": 210,
              "name": "SocialSecurity",
              "description": "Social security contribution: 10% of gross income. Uses WageType references (not collector) to work in both normal and retro runs.",
              "valueExpression": "(WageType[100] + WageType[110]) * 0.10M",
              "collectors": [ "Deductions" ],
              "clusters": [ "Legal", "Retro" ]
            },
            {
              "wageTypeNumber": 212,
              "name": "SocialSecurityDelta",
              "description": "Sum of all retro-period corrections for WT 210",
              "valueExpression": "GetWageTypeRetroResultSum(210)",
              "clusters": [ "Legal" ]
            }
          ]
        }
      ],
