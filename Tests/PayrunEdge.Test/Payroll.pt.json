      "regulations": [
        {
          "name": "PayrunEdge",
          "description": "Payrun edge case tests: period boundaries, case value overlap/touching/splitting, eval-date edges (period-start, period-end, cycle-end), retro, forecast",
          "cases": [
            {
              "name": "BaseSalary",
              "caseType": "Employee",
              "defaultReason": "Set base salary",
              "fields": [
                {
                  "name": "BaseSalary",
                  "valueType": "Money",
                  "timeType": "CalendarPeriod",
                  "description": "CalendarPeriod field — used for period-boundary and retro tests"
                }
              ]
            },
            {
              "name": "Supplement",
              "caseType": "Employee",
              "defaultReason": "Set supplement",
              "fields": [
                {
                  "name": "Supplement",
                  "valueType": "Money",
                  "timeType": "Period",
                  "description": "Period field — used for touching-boundary test (value A end == value B start)"
                }
              ]
            },
            {
              "name": "SplitBonus",
              "caseType": "Employee",
              "defaultReason": "Set split bonus",
              "fields": [
                {
                  "name": "SplitBonus",
                  "valueType": "Money",
                  "timeType": "Period",
                  "description": "Period field starting mid-period (Feb 15) — tests time-data splitting behaviour"
                }
              ]
            },
            {
              "name": "OverlapAllowance",
              "caseType": "Employee",
              "defaultReason": "Set overlap allowance",
              "fields": [
                {
                  "name": "OverlapAllowance",
                  "valueType": "Money",
                  "timeType": "CalendarPeriod",
                  "description": "CalendarPeriod field — two entries for the same period, different created timestamps; latest created must win"
                }
              ]
            },
            {
              "name": "EvalDateEdgeValue",
              "caseType": "Employee",
              "defaultReason": "Set eval-date edge value",
              "fields": [
                {
                  "name": "EvalDateEdgeValue",
                  "valueType": "Money",
                  "timeType": "CalendarPeriod",
                  "description": "Case value with created == evaluationDate. PE uses strict < for visibility: created=Jun1, evalDate=Jun1 => NOT visible (actual=0). End=Jun30 (inclusive) keeps value out of Jul."
                }
              ]
            }
          ],
          "wageTypes": [
            {
              "wageTypeNumber": 101,
              "name": "BaseSalary",
              "description": "Scenario: CalendarPeriod boundary. Direct case value read. Used in retro cluster so retro recalculates it.",
              "valueExpression": "CaseValue[\"BaseSalary\"]",
              "clusters": [
                "Legal",
                "Retro"
              ]
            },
            {
              "wageTypeNumber": 102,
              "name": "Supplement",
              "description": "Scenario: Period touching. Two Period entries where end-of-A == start-of-B (Apr 1). Apr run must return value B (200).",
              "valueExpression": "CaseValue[\"Supplement\"]",
              "clusters": [
                "Legal"
              ]
            },
            {
              "wageTypeNumber": 103,
              "name": "SplitBonus",
              "description": "Scenario: Time-data splitting. Period value starts Feb 15 (mid-period). Jan run: 0 (not yet active). Feb run: 300 (start within period).",
              "valueExpression": "var v = CaseValue[\"SplitBonus\"]; return v != null ? (decimal)v : 0m;",
              "clusters": [
                "Legal"
              ]
            },
            {
              "wageTypeNumber": 104,
              "name": "OverlapAllowance",
              "description": "Scenario: Overlapping case values. Two entries for Apr (same CalendarPeriod), created Mar 1 (500) and Apr 1 (600). Latest created (600) must win.",
              "valueExpression": "var v = CaseValue[\"OverlapAllowance\"]; return v != null ? (decimal)v : 0m;",
              "clusters": [
                "Legal"
              ]
            },
            {
              "wageTypeNumber": 105,
              "name": "EvalDateDay",
              "description": "Exposes EvaluationDate.Day. Used to verify edge runs: EvalStart run => 1, EvalEnd run => 31, CycleEnd run => 31.",
              "valueExpression": "return (decimal)EvaluationDate.Day;",
              "clusters": [
                "Legal"
              ]
            },
            {
              "wageTypeNumber": 106,
              "name": "IsRetroIndicator",
              "description": "Returns 1 in retro recalculation sub-runs, 0 in all main runs. In Retro cluster so it is computed during retro.",
              "valueExpression": "return IsRetroPayrun ? 1m : 0m;",
              "clusters": [
                "Legal",
                "Retro"
              ]
            },
            {
              "wageTypeNumber": 107,
              "name": "IsForecastIndicator",
              "description": "Returns 1 when Forecast property is non-empty (forecast run), 0 otherwise.",
              "valueExpression": "return !string.IsNullOrEmpty(Forecast) ? 1m : 0m;",
              "clusters": [
                "Legal"
              ]
            },
            {
              "wageTypeNumber": 108,
              "name": "EvalDateEdgeCaseValue",
              "description": "Scenario: case value with created == evaluationDate. PE uses strict < for case value visibility: created=Jun1, evalDate=Jun1 => NOT visible => 0. Documents actual PE behaviour.",
              "valueExpression": "var v = CaseValue[\"EvalDateEdgeValue\"]; return v != null ? (decimal)v : 0m;",
              "clusters": [
                "Legal"
              ]
            },
            {
              "wageTypeNumber": 109,
              "name": "EvalDateEdgeWageType",
              "description": "Scenario: wage type with created == evaluationDate of Jun24-EvalStart run. PE uses <= for WageType derivation. Must be derived for evalDate >= Jun 1 (value 42).",
              "valueExpression": "return 42m;",
              "created": "2024-06-01T00:00:00.0Z",
              "clusters": [
                "Legal"
              ]
            },
            {
              "wageTypeNumber": 202,
              "name": "BaseSalaryRetroDiff",
              "description": "Scenario: retro diff. Aggregates retro delta of WT 101 across all retro sub-runs of the current job. Mar24: +1000 (Feb retroactively raised 3000->4000).",
              "valueExpression": "GetWageTypeRetroResultSum(101)",
              "clusters": [
                "Legal"
              ]
            }
          ]
        }
      ],
