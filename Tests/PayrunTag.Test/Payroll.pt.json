      "regulations": [
        {
          "name": "PayrunTag.Test",
          "description": "Tests GetWageTypeResults with Tag filter — verifies tag isolation for retro sub-runs scheduled via ScheduleRetroPayrun",
          "cases": [
            {
              "name": "Salary",
              "caseType": "Employee",
              "defaultReason": "Set salary",
              "fields": [
                {
                  "name": "Salary",
                  "valueType": "Money",
                  "timeType": "Period"
                }
              ]
            }
          ],
          "wageTypes": [
            {
              "wageTypeNumber": 100,
              "name": "Salary",
              "description": "Salary — schedules an Alpha-tagged retro sub-run for the prior period (Legal only, never runs in retro)",
              "valueExpression": "ScheduleRetroPayrun(PeriodStart.SubtractMonths(1), new[] { \"Alpha\" }); return CaseValue[\"Salary\"];",
              "clusters": [ "Legal" ]
            },
            {
              "wageTypeNumber": 110,
              "name": "RetroMarker",
              "description": "Returns 750 inside any retro sub-run, 0 in main runs — the tagged result queried by WT201/202",
              "valueExpression": "IsRetroPayrun ? 750m : 0m",
              "clusters": [ "Legal", "Retro" ]
            },
            {
              "wageTypeNumber": 201,
              "name": "TagAlphaResult",
              "description": "Queries WT110 for the prior period with Tag=Alpha — expects 750 from the Alpha retro sub-run",
              "valueExpression": "GetWageTypeResults(new(110m, PeriodStart.SubtractMonths(1), PeriodEnd) { Tag = \"Alpha\" }).Sum()",
              "clusters": [ "Legal" ]
            },
            {
              "wageTypeNumber": 202,
              "name": "TagBetaResult",
              "description": "Queries WT110 for the prior period with Tag=Beta — expects 0 (no Beta retro was ever scheduled)",
              "valueExpression": "GetWageTypeResults(new(110m, PeriodStart.SubtractMonths(1), PeriodEnd) { Tag = \"Beta\" }).Sum()",
              "clusters": [ "Legal" ]
            }
          ]
        }
