              "fields": [
                {
                  "name": "Salary",
                  "valueType": "Money",
                  "timeType": "CalendarPeriod",
                  "created": "2024-01-01T00:00:00.0Z"
                }
              ]
            }
          ],
          "wageTypes": [
            {
              "wageTypeNumber": 101,
              "name": "AgeAllowance",
              "description": "Reads BirthDate (Timeless) each period — must never throw NullRef",
              "valueExpression": "var bd = CaseValue[\"BirthDate\"]; if (bd == null) return 0M; var age = bd.ValueAs<DateTime>().Age(PeriodEnd); return age >= 50 ? CaseValue[\"Salary\"] * 0.075M : 0M;",
              "created": "2024-01-01T00:00:00.0Z"
            },
            {
              "wageTypeNumber": 102,
              "name": "TaxAmount",
              "description": "Reads TaxCode (Timeless, optional) — null-safe; returns 0 when absent",
              "valueExpression": "var tc = CaseValue[\"TaxCode\"]; if (tc == null) return 0M; var code = tc.ValueAs<string>(); if (string.IsNullOrEmpty(code)) return 0M; return code == \"A\" ? CaseValue[\"Salary\"] * 0.05M : code == \"B\" ? CaseValue[\"Salary\"] * 0.08M : 0M;",
              "created": "2024-01-01T00:00:00.0Z"
            }
          ]
        }
