          "description": "Regression test: timeless case value codepath (NullRef fix)",
          "created": "2024-01-01T00:00:00.0Z",
          "cases": [
            {
              "name": "PersonalData",
              "caseType": "Employee",
              "created": "2024-01-01T00:00:00.0Z",
