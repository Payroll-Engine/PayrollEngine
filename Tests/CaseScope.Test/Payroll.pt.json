            },
            {
              "wageTypeNumber": 102,
              "name": "EmployerContribution",
              "description": "Company scope: Salary multiplied by EmployerRate from Company case",
              "valueExpression": "return CaseValue[\"Salary\"] * CaseValue[\"EmployerRate\"];",
              "created": "2024-01-01T00:00:00.0Z"
            },
            {
              "wageTypeNumber": 103,
              "name": "BaseSalary",
              "description": "Employee scope: direct read of Salary from Employee case",
